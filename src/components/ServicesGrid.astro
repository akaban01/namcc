---
const services = [
	{ title: 'Food Pantry', href: '/services/food-pantry-delivery/', icon: 'M4 7h16l-1.5 12.5a2 2 0 0 1-2 1.5H7.5a2 2 0 0 1-2-1.5L4 7Zm4-3a4 4 0 0 1 8 0' },
	{ title: 'Free Clinic', href: '/services/medical-health-clinic/', icon: 'M12 2a5 5 0 0 1 5 5v2h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-6a2 2 0 0 1 2-2h2V7a5 5 0 0 1 5-5Zm0 9v6m-3-3h6' },
	{ title: 'Funeral Services', href: '/services/funeral-services/', icon: 'M12 3v14m-7 4h14M8 13l4 4 4-4' },
	{ title: 'Humanitarian Support', href: '/services/humanitarian-assistance/', icon: 'M12 21s-7-4.4-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 6c-2.5 4.6-9.5 9-9.5 9Z' },
	{ title: 'Matrimonial Services', href: '/services/nikah-services/', icon: 'M8 12a4 4 0 1 0 0-.001M16 12a4 4 0 1 0 0-.001M9.5 9.5 14.5 14.5' },
	{ title: "Imam's Corner", href: '/scholars/', icon: 'M4 19V9l8-5 8 5v10M9 19v-6h6v6' },
	{ title: 'Interested in Islam', href: '/interested-in-islam/', icon: 'M12 2 3 7v10l9 5 9-5V7l-9-5Zm0 6v8' },
	{ title: 'Convert Services', href: '/convert-services/', icon: 'M12 2v6m0 0-3-3m3 3 3-3M4 14a8 8 0 0 0 16 0' },
];
---

<section class="bg-brand-50/60 py-20">
	<div class="mx-auto max-w-7xl px-6">
		<div class="mb-10 text-center">
			<span class="text-xs font-bold uppercase tracking-widest text-gold-600">How We Serve</span>
			<h2 class="mt-2 text-3xl font-extrabold text-brand-700 sm:text-4xl">Services</h2>
		</div>
		<div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
			{services.map((s) => (
				<a href={s.href} class="group flex flex-col items-center gap-3 rounded-xl bg-white p-6 text-center shadow-sm ring-1 ring-neutral-100 transition hover:-translate-y-1 hover:shadow-lg">
					<span class="flex size-14 items-center justify-center rounded-full bg-brand-50 text-brand-600 transition group-hover:bg-brand-600 group-hover:text-white">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="size-7">
							<path d={s.icon} />
						</svg>
					</span>
					<span class="text-sm font-semibold text-neutral-800 group-hover:text-brand-700">{s.title}</span>
				</a>
			))}
		</div>
	</div>
</section>
