---
const services = [
	{ title: 'Food Pantry', href: '/services/food-pantry-delivery/', icon: '/images/services/food-pantry.png' },
	{ title: 'Free Clinic', href: '/services/medical-health-clinic/', icon: '/images/services/free-clinic.png' },
	{ title: 'Funeral Services', href: '/services/funeral-services/', icon: '/images/services/funeral-services.png' },
	{ title: 'Humanitarian Support', href: '/services/humanitarian-assistance/', icon: '/images/services/humanitarian-support.png' },
	{ title: 'Matrimonial Services', href: '/services/nikah-services/', icon: '/images/services/matrimonial-services.png' },
	{ title: "Imam's Corner", href: '/scholars/', icon: '/images/services/imams-corner.png' },
	{ title: 'Interested in Islam', href: '/interested-in-islam/', icon: '/images/services/interested-in-islam.png' },
	{ title: 'Convert Services', href: '/convert-services/', icon: '/images/services/convert-services.png' },
];
---

<section class="bg-brand-600 py-20">
	<div class="mx-auto max-w-7xl px-6">
		<div class="mb-10 text-center">
			<span class="text-xs font-bold uppercase tracking-widest text-gold-400">How We Serve</span>
			<h2 class="mt-2 text-3xl font-extrabold text-white sm:text-4xl">Services</h2>
		</div>
		<div class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 lg:grid-cols-4">
			{services.map((s) => (
				<a href={s.href} class="group flex flex-col items-center gap-3 text-center transition hover:-translate-y-1">
					<img src={s.icon} alt="" class="size-16" />
					<span class="text-base font-medium text-[#f0e8d3] transition group-hover:text-white">{s.title}</span>
				</a>
			))}
		</div>
	</div>
</section>
