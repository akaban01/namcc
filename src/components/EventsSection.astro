---
interface EventItem {
	title: string;
	category: string;
	date: Date;
	time?: string;
	summary: string;
	link?: string;
}

interface Props {
	events: EventItem[];
}

const { events } = Astro.props;
const categories = ['All', 'General', 'Youth', 'Sisters', 'Ramadan', 'Brothers'];

const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<section class="mx-auto max-w-7xl px-6 py-20">
	<div class="mb-10 flex flex-wrap items-end justify-between gap-4">
		<div>
			<span class="text-xs font-bold uppercase tracking-widest text-gold-600">What's Happening</span>
			<h2 class="mt-2 text-3xl font-extrabold text-brand-700 sm:text-4xl">Events</h2>
		</div>
		<div class="flex flex-wrap gap-2" role="tablist" aria-label="Event categories">
			{categories.map((cat, i) => (
				<button
					type="button"
					class:list={[
						'event-filter rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-wide transition',
						i === 0 ? 'bg-brand-600 text-white' : 'bg-brand-50 text-brand-700 hover:bg-brand-100',
					]}
					data-category={cat}
				>
					{cat}
				</button>
			))}
		</div>
	</div>

	{events.length === 0 ? (
		<p class="rounded-xl bg-neutral-50 p-8 text-center text-neutral-500">No upcoming events posted right now — check back soon.</p>
	) : (
		<div id="events-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{events.map((event) => (
				<article data-category={event.category} class="event-card flex flex-col rounded-xl border border-neutral-100 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
					<span class="mb-3 inline-flex w-fit items-center rounded-full bg-brand-50 px-3 py-1 text-[11px] font-bold uppercase tracking-wide text-brand-700">
						{event.category}
					</span>
					<h3 class="text-lg font-bold text-neutral-900">{event.title}</h3>
					<p class="mt-1 text-sm font-semibold text-gold-600">
						{dateFmt.format(event.date)}{event.time ? ` · ${event.time}` : ''}
					</p>
					<p class="mt-3 flex-1 text-sm text-neutral-600">{event.summary}</p>
					{event.link && (
						<a href={event.link} class="mt-4 text-sm font-semibold text-brand-600 hover:text-brand-800">Learn more &rarr;</a>
					)}
				</article>
			))}
		</div>
	)}
</section>

<script>
	const buttons = document.querySelectorAll<HTMLButtonElement>('.event-filter');
	const cards = document.querySelectorAll<HTMLElement>('.event-card');

	buttons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const category = btn.dataset.category;
			buttons.forEach((b) => b.classList.remove('bg-brand-600', 'text-white'));
			buttons.forEach((b) => b.classList.add('bg-brand-50', 'text-brand-700'));
			btn.classList.remove('bg-brand-50', 'text-brand-700');
			btn.classList.add('bg-brand-600', 'text-white');

			cards.forEach((card) => {
				const show = category === 'All' || card.dataset.category === category;
				card.style.display = show ? '' : 'none';
			});
		});
	});
</script>
