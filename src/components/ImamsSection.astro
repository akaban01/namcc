---
interface ImamItem {
	name: string;
	title: string;
	photo?: string;
	availability?: string;
	slug: string;
}

interface Props {
	imams: ImamItem[];
}

const { imams } = Astro.props;
---

<section class="mx-auto max-w-7xl px-6 py-20">
	<div class="mb-10 text-center">
		<span class="text-xs font-bold uppercase tracking-widest text-gold-600">Our Scholars</span>
		<h2 class="mt-2 text-3xl font-extrabold text-brand-700 sm:text-4xl">Meet the Imams</h2>
	</div>
	<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
		{imams.map((imam) => (
			<div class="flex flex-col items-center rounded-2xl border border-neutral-100 bg-white p-8 text-center shadow-sm">
				<img src={imam.photo ?? '/images/imams/placeholder.svg'} alt={imam.name} class="mb-4 size-32 rounded-full object-cover ring-4 ring-brand-50" />
				<h3 class="text-lg font-bold text-neutral-900">{imam.name}</h3>
				<p class="text-sm font-semibold uppercase tracking-wide text-gold-600">{imam.title}</p>
				{imam.availability && <p class="mt-3 text-sm text-neutral-600">{imam.availability}</p>}
				<div class="mt-5 flex gap-3">
					<a href={`/scholars/${imam.slug}/`} class="rounded-full bg-brand-600 px-5 py-2 text-xs font-semibold uppercase tracking-wide text-white transition hover:bg-brand-700">Read More</a>
					<a href="/get-in-touch/" class="rounded-full border border-brand-600 px-5 py-2 text-xs font-semibold uppercase tracking-wide text-brand-700 transition hover:bg-brand-50">Ask Imam</a>
				</div>
			</div>
		))}
	</div>
</section>
