---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const imams = await getCollection('imams');
	return imams.map((imam) => ({
		params: { slug: imam.id },
		props: { imam },
	}));
}

const { imam } = Astro.props;
const { Content } = await render(imam);
---

<BaseLayout title={imam.data.name} description={imam.data.title}>
	<PageHeader title={imam.data.name} breadcrumb={imam.data.name} />
	<section class="mx-auto flex max-w-3xl flex-col items-center gap-4 px-6 py-16 text-center">
		<img src={imam.data.photo ?? '/images/imams/placeholder.svg'} alt={imam.data.name} class="size-40 rounded-full object-cover ring-4 ring-brand-50" />
		<h2 class="text-2xl font-bold text-neutral-900">{imam.data.name}</h2>
		<p class="text-sm font-semibold uppercase tracking-wide text-gold-600">{imam.data.title}</p>
		{imam.data.availability && <p class="text-neutral-600">{imam.data.availability}</p>}
		<div class="prose prose-neutral mt-4 max-w-none text-left prose-a:text-brand-600">
			<Content />
		</div>
		<a href="/get-in-touch/" class="mt-4 rounded-full bg-brand-600 px-6 py-3 text-sm font-semibold uppercase tracking-wide text-white transition hover:bg-brand-700">
			Ask Imam
		</a>
	</section>
</BaseLayout>
