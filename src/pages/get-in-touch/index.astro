---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContactSection from '../../components/ContactSection.astro';
import { getEntry, render } from 'astro:content';
import site from '../../content/settings/site.json';

const page = (await getEntry('pages', 'get-in-touch'))!;
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
	<PageHeader title={page.data.title} />
	<article class="prose prose-neutral mx-auto max-w-3xl px-6 pt-16 prose-headings:text-brand-700 prose-a:text-brand-600">
		<Content />
	</article>
	<ContactSection address={site.address} email={site.email} phone={site.phone} mapEmbedUrl={site.mapEmbedUrl} />
</BaseLayout>
