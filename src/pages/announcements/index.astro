---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const announcements = (await getCollection('announcements')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<BaseLayout title="Announcements" description="Latest announcements and news from NAMCC.">
	<PageHeader title="Announcements" />
	<section class="mx-auto max-w-4xl px-6 py-16">
		{announcements.length === 0 ? (
			<p class="text-center text-neutral-500">No announcements posted right now — check back soon.</p>
		) : (
			<div class="flex flex-col divide-y divide-neutral-100">
				{announcements.map((a) => (
					<article class="py-8">
						<p class="text-xs font-bold uppercase tracking-wide text-gold-600">{dateFmt.format(a.data.date)}</p>
						<h2 class="mt-2 text-2xl font-bold text-brand-700">{a.data.title}</h2>
						<p class="mt-3 text-neutral-600">{a.data.summary}</p>
						{a.data.link && (
							<a href={a.data.link} class="mt-4 inline-block text-sm font-semibold text-brand-600 hover:text-brand-800">
								Learn more &rarr;
							</a>
						)}
					</article>
				))}
			</div>
		)}
	</section>
</BaseLayout>
